{
  "name": "yuanio",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "launch": "bun run packages/cli/src/index.ts launch",
    "check:tabler-icons": "python \"tools/check_tabler_icons.py\"",
    "check:tabler-icons:fix": "python \"tools/check_tabler_icons.py\" --fix",
    "check:android-guards": "python \"tools/check_android_guards.py\"",
    "check:android-architecture": "python \"tools/check_android_architecture.py\"",
    "check:android-deferred-gates": "python \"tools/check_android_deferred_reentry.py\"",
    "telegram:start": "powershell -ExecutionPolicy Bypass -File \"./scripts/telegram-bot.ps1\" start",
    "telegram:start:lan": "powershell -ExecutionPolicy Bypass -File \"./scripts/telegram-bot.ps1\" start -NetworkMode lan -Restart",
    "telegram:start:cloudflare": "powershell -ExecutionPolicy Bypass -File \"./scripts/telegram-bot.ps1\" start -NetworkMode cloudflare -Restart",
    "telegram:stop": "powershell -ExecutionPolicy Bypass -File \"./scripts/telegram-bot.ps1\" stop",
    "telegram:status": "powershell -ExecutionPolicy Bypass -File \"./scripts/telegram-bot.ps1\" status",
    "typecheck": "tsc --noEmit -p packages/shared && tsc --noEmit -p packages/relay-server && tsc --noEmit -p packages/cli",
    "baseline:protocol:quick": "bun run packages/shared/src/test-crypto-web.ts && bun run packages/shared/src/test-uuid.ts && cargo test --manifest-path \"crates/relay-server/Cargo.toml\" && bun run packages/cli/src/test-relay-options.ts && bun test packages/cli/src/__tests__/local-server.test.ts packages/cli/src/remote/__tests__/queue.test.ts packages/cli/src/remote/__tests__/queue-persist.test.ts packages/cli/src/remote/__tests__/dispatch.test.ts && bun run typecheck",
    "baseline:protocol:e2e": "bun run packages/cli/src/test-protocol-e2e-baseline.ts",
    "baseline:protocol": "bun run baseline:protocol:quick && bun run baseline:protocol:e2e",
    "android:build:debug": "powershell -ExecutionPolicy Bypass -File \"./scripts/android-install-debug.ps1\" -SkipInstall",
    "android:install:debug": "powershell -ExecutionPolicy Bypass -File \"./scripts/android-install-debug.ps1\"",
    "i18n:add": "bun run scripts/i18n/add-entry.ts",
    "i18n:add:ps": "bun run scripts/i18n/add-entry.ts",
    "i18n:sync": "bun run scripts/i18n/sync.ts",
    "i18n:check": "bun run scripts/i18n/check.ts",
    "test:skills:core": "node tests/skill-triggering/run-all.cjs --mode local --cases tests/skill-triggering/cases.json",
    "test:skills:core:auto": "node tests/skill-triggering/run-all.cjs --mode auto --timeout-ms 600000 --cases tests/skill-triggering/cases.auto.json",
    "test:skills:core:runner": "node tests/skill-triggering/run-all.cjs --mode runner --timeout-ms 600000 --cases tests/skill-triggering/cases.auto.json",
    "test:skills:constraints": "node tests/skill-triggering/run-all.cjs --mode local --cases tests/skill-triggering/cases.constraints.json",
    "test:hooks:smoke": "node tests/hooks/sy-hooks-smoke.cjs",
    "test:skills:clean-output": "node scripts/cleanup-skill-trigger-output.cjs",
    "test:skills:smoke:auto": "node tests/skill-triggering/run-all.cjs --mode auto --max-turns 2 --timeout-ms 180000 --cases tests/skill-triggering/cases.smoke.json",
    "test:skills:smoke:runner": "node tests/skill-triggering/run-all.cjs --mode runner --max-turns 2 --timeout-ms 180000 --cases tests/skill-triggering/cases.smoke.json",
    "workflow:sync:from-source": "python \"seeyue-workflows/scripts/sync-workflow-assets.py\" --target-root \".\"",
    "workflow:sync:check": "python \"seeyue-workflows/scripts/sync-workflow-assets.py\" --target-root \".\" --check"
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "typescript": "^5.9.3"
  }
}
